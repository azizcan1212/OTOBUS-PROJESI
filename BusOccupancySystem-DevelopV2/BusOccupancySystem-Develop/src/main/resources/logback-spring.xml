<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProfile name="default,dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <!-- correlationId MDC'den otomatik gelir — CorrelationIdFilter tarafindan set edilir -->
                <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level [%X{correlationId:-NO-CORR}] %logger{36} - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <!-- Gelistirme sirasinda SQL sorgularini gormek icin DEBUG seviyesi -->
        <logger name="com.bus.occupancy.system" level="DEBUG"/>
    </springProfile>

    <springProfile name="prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <!-- Uretim ortaminda JSON formatli yapisal loglama -->
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.bus.occupancy.system" level="INFO"/>
    </springProfile>

</configuration>
